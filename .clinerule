# ============================================================
# .clinerule — 工程标准约束规则文件
# ============================================================
# 本文件定义不同工作场景下应遵循的规范文件。
# 所有开发人员（含 AI 辅助工具）在进行对应操作时，
# 必须参考指定的 rules/ 目录下的规范文档。
# ============================================================

[general]
# 规范文件目录
rules_dir = rules/

# ============================================================
# 场景 → 规范文件映射
# ============================================================

[scenario:write_code]
# 编写代码（新增组件、修改逻辑、重构等）
description = 编写或修改任何 Vue/JS 代码时
  files =
    rules/coding-standards.md
    rules/layout_standards.md
    rules/sys-button-usage.md
    rules/sys-table-usage.md
    rules/sys-tag-usage.md
    rules/page-header-usage.md
  rules =
    - 遵循文件命名规范（PascalCase / camelCase / kebab-case）
    - 遵循 Vue SFC 结构规范（script setup → template → style scoped）
    - 遵循 Composition API 使用原则
    - Element Plus 组件无需手动 import，API 方法需要 import
    - 所有按钮使用 SysButton 组件，禁止直接使用 el-button
    - 所有表格使用 SysTable 组件，禁止直接使用 el-table / el-pagination
    - 页面组件 template 根元素必须使用 class="page-content"，禁止自定义外层 class
    - 所有页面标题区域必须使用 PageHeader 组件，禁止手写 <div class="page-header"> 裸结构
    - 所有状态标签、天数标签使用 SysTag 组件，禁止使用 el-tag 或手写样式标签

[scenario:write_style]
# 编写样式
description = 编写 CSS / 组件样式时
files = rules/style-standards.md
rules =
  - 组件样式必须使用 scoped
  - 类名使用 kebab-case 或 BEM
  - Element Plus 覆盖使用 :deep()
  - 优先使用 CSS 变量

[scenario:git_commit]
# Git 提交
description = 提交代码时
files = rules/git-commit-standards.md
rules =
  - Commit message 格式：type(scope): subject
  - 分支命名遵循 feature/ fix/ hotfix/ release/ 规范
  - 提交前自检：编译通过、无 console.log/ debugger、勿提交 node_modules

[scenario:code_review]
# 代码审查
description = 进行代码审查时
files =
  rules/coding-standards.md
  rules/style-standards.md
  rules/layout_standards.md
  rules/sys-button-usage.md
  rules/sys-table-usage.md
  rules/sys-tag-usage.md
rules =
  - 检查命名是否规范
  - 检查 Vue SFC 结构顺序
  - 检查样式作用域是否正确
  - 检查是否有硬编码值
  - 检查按钮是否使用 SysButton 而非 el-button
  - 检查表格是否使用 SysTable 而非 el-table / el-pagination
  - 检查标签是否使用 SysTag 而非 el-tag 或裸 span

[scenario:create_component]
# 新建组件
description = 创建新的 Vue 组件时
files =
  rules/coding-standards.md
  rules/style-standards.md
  rules/layout_standards.md
  rules/sys-button-usage.md
  rules/sys-table-usage.md
  rules/sys-tag-usage.md
rules =
  - 文件使用 PascalCase 命名
  - 结构：script setup → template → style scoped
  - 类名使用 kebab-case
  - 组件顶部添加用途注释
  - 组件内按钮使用 SysButton，不用 el-button
  - 组件内表格使用 SysTable，不用 el-table / el-pagination
  - 页面组件 template 根元素必须使用 class="page-content"，禁止自定义外层 class
  - 组件内状态标签使用 SysTag，不用 el-tag 或手写标签

[scenario:refactor]
# 重构代码
description = 进行代码重构时
files =
  rules/coding-standards.md
  rules/style-standards.md
  rules/layout_standards.md
  rules/sys-button-usage.md
  rules/sys-table-usage.md
  rules/sys-tag-usage.md
rules =
  - 保持 SFC 块级顺序
  - 优先使用 Composition API
  - 抽取可复用逻辑到 composables/
  - 不改变外部行为（重构不修 Bug）
  - 将 el-button 替换为 SysButton
  - 将 el-table / el-pagination 替换为 SysTable
  - 将 el-tag / 手写样式标签替换为 SysTag

[scenario:setup_project]
# 项目初始化 / 配置
description = 项目初始化或修改工程配置时
files = rules/coding-standards.md
rules =
  - 遵循目录结构规范
  - 全局样式放入 src/style.css
  - 配置 Vite / 插件遵循最小化原则